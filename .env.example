# Azure AI Foundry Agent Platform - Environment Variables
# Copy this file to .env and fill in your values

# Required: Your Azure AI Foundry project endpoint URL
AZURE_AI_PROJECT_ENDPOINT=<your-project-endpoint>

# Environment name (dev, qa, prod)
ENVIRONMENT=dev

# Azure Key Vault name (optional)
AZURE_KEY_VAULT_NAME=

# Agent configuration (override per agent or use defaults from each agent's config.py)
# AGENT_NAME=
# AGENT_MODEL=gpt-4o

# Integration toggles and connection IDs (code_interpreter, web_search, github, knowledge_source)
# are NOT set here — each agent controls its own tools and connections in its config.py.
