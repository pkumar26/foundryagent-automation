# Azure AI Foundry Agent Platform - Environment Variables
# Copy this file to .env and fill in your values

# Required: Your Azure AI Foundry project connection string
FOUNDRY_PROJECT_CONNECTION_STRING=<your-connection-string>

# Environment name (dev, qa, prod)
ENVIRONMENT=dev

# Azure Key Vault name (optional)
AZURE_KEY_VAULT_NAME=

# Agent configuration (override per agent or use defaults)
AGENT_NAME=
AGENT_MODEL=gpt-4o

# Knowledge source integration (deferred)
KNOWLEDGE_SOURCE_ENABLED=false
AZURE_AI_SEARCH_ENDPOINT=
AZURE_AI_SEARCH_INDEX_NAME=

# GitHub MCP integration (deferred)
GITHUB_MCP_ENABLED=false
GITHUB_MCP_ENDPOINT=
GITHUB_MCP_TOKEN_SECRET_NAME=
