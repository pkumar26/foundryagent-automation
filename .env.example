# Azure AI Foundry Agent Platform - Environment Variables
# Copy this file to .env and fill in your values

# Required: Your Azure AI Foundry project connection string
FOUNDRY_PROJECT_CONNECTION_STRING=<your-connection-string>

# Environment name (dev, qa, prod)
ENVIRONMENT=dev

# Azure Key Vault name (optional)
AZURE_KEY_VAULT_NAME=

# Agent configuration (override per agent or use defaults from each agent's config.py)
# AGENT_NAME=
# AGENT_MODEL=gpt-4o

# Knowledge source integration
KNOWLEDGE_SOURCE_ENABLED=false
AZURE_AI_SEARCH_CONNECTION_ID=
AZURE_AI_SEARCH_INDEX_NAME=

# GitHub PAT for writing analysis files to the output repo (used by write_github_file tool).
# Needs repo scope (classic) or Contents: Read and write (fine-grained).
GITHUB_PAT=
